{
  "name": "liveline-svelte",
  "version": "0.0.1",
  "type": "module",
  "description": "Svelte fork of Liveline — real-time animated charts with line, candlestick, and multi-series modes",
  "keywords": [
    "svelte",
    "chart",
    "canvas",
    "real-time",
    "animation",
    "line-chart",
    "candlestick",
    "ohlc",
    "multi-series",
    "multi-line"
  ],
  "license": "MIT",
  "author": "VastBlast",
  "contributors": [
    "Benji Taylor (original Liveline project)",
    "VastBlast (Svelte fork and ongoing maintenance)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VastBlast/liveline-svelte.git"
  },
  "homepage": "https://github.com/VastBlast/liveline-svelte#readme",
  "bugs": "https://github.com/VastBlast/liveline-svelte/issues",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "dev": "vite --config dev/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^22.19.15",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  }
}
