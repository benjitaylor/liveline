{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["svelte", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "dev/**/*.ts", "dev/**/*.svelte"]
}
